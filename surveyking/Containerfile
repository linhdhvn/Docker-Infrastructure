# Use a lightweight JRE base image
FROM openjdk:8-jre-alpine

# Set working directory
WORKDIR /app

# Copy the compiled JAR file (ensure you've built it first via Maven/Gradle)
COPY target/surveyking-v*.jar app.jar

# Expose the default application port
EXPOSE 1991

# Volume definitions for persistence
VOLUME ["/app/db", "/app/files", "/app/logs"]

# Start the application
ENTRYPOINT ["java", "-jar", "app.jar"]
